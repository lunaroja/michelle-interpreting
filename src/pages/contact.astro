---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact & Book" description="Book a Spanish interpreting session or send an inquiry. On-site, video, and phone interpreting available for healthcare providers.">

  <!-- HERO -->
  <section class="bg-deep-forest py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-20"
         style="background: radial-gradient(ellipse at 70% 40%, #7A9E7E 0%, transparent 55%);">
    </div>
    <div class="relative max-w-6xl mx-auto px-6">
      <p class="text-xs tracking-[4px] uppercase text-clay mb-4 font-body">Get in Touch</p>
      <h1 class="font-display text-5xl text-cream mb-4">Let's work together.</h1>
      <p class="text-mist/80 max-w-lg leading-relaxed">
        Book a session directly or send a request — Michelle will confirm availability
        within one business day.
      </p>
    </div>
  </section>

  <!-- CONTACT CONTENT -->
  <section class="max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-16">

    <!-- Form -->
    <div>

      <!-- Intro call quick-book banner -->
      <a href="/intro" target="_blank" rel="noopener noreferrer"
         class="flex items-center justify-between bg-clay/10 border border-clay/30 rounded-2xl p-5 mb-10 hover:bg-clay/15 transition-colors group">
        <div>
          <p class="text-xs tracking-[2px] uppercase text-clay font-body mb-1">Free · 30 minutes</p>
          <p class="font-display text-lg text-deep-forest leading-snug">Book a Free Intro Call</p>
          <p class="text-sm text-bark/60 mt-1">Schedule a quick chat with Michelle — no commitment.</p>
        </div>
        <span class="text-clay text-xl group-hover:translate-x-1 transition-transform flex-shrink-0 ml-4">→</span>
      </a>

      <h2 class="font-display text-2xl text-deep-forest mb-8">Request a Session</h2>

      <!-- Replace the action URL with your Formspree form ID: https://formspree.io -->
      <form
        method="POST"
        action="https://formspree.io/f/REPLACE_WITH_FORMSPREE_ID"
        class="space-y-5"
      >

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-xs tracking-[2px] uppercase text-earth mb-2 font-body" for="name">
              Your Name *
            </label>
            <input
              type="text" id="name" name="name" required
              class="w-full bg-cream border border-mist rounded-xl px-4 py-3 text-sm text-bark placeholder-bark/40 focus:outline-none focus:border-sage transition-colors"
              placeholder="Jane Smith"
            />
          </div>
          <div>
            <label class="block text-xs tracking-[2px] uppercase text-earth mb-2 font-body" for="organization">
              Organization
            </label>
            <input
              type="text" id="organization" name="organization"
              class="w-full bg-cream border border-mist rounded-xl px-4 py-3 text-sm text-bark placeholder-bark/40 focus:outline-none focus:border-sage transition-colors"
              placeholder="Community Health Clinic"
            />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-xs tracking-[2px] uppercase text-earth mb-2 font-body" for="email">
              Email Address *
            </label>
            <input
              type="email" id="email" name="email" required
              class="w-full bg-cream border border-mist rounded-xl px-4 py-3 text-sm text-bark placeholder-bark/40 focus:outline-none focus:border-sage transition-colors"
              placeholder="jane@clinic.org"
            />
          </div>
          <div>
            <label class="block text-xs tracking-[2px] uppercase text-earth mb-2 font-body" for="phone">
              Phone Number
            </label>
            <input
              type="tel" id="phone" name="phone"
              class="w-full bg-cream border border-mist rounded-xl px-4 py-3 text-sm text-bark placeholder-bark/40 focus:outline-none focus:border-sage transition-colors"
              placeholder="(555) 000-0000"
            />
          </div>
        </div>

        <div>
          <label class="block text-xs tracking-[2px] uppercase text-earth mb-2 font-body" for="service">
            Service Needed
          </label>
          <select
            id="service" name="service"
            class="w-full bg-cream border border-mist rounded-xl px-4 py-3 text-sm text-bark focus:outline-none focus:border-sage transition-colors appearance-none"
          >
            <option value="">Select a service...</option>
            <option value="on-site">On-Site Interpreting</option>
            <option value="video">Video Remote Interpreting (VRI)</option>
            <option value="phone">Phone Interpreting (OPI)</option>
            <option value="document">Document Translation</option>
            <option value="partnership">Provider Partnership / Contract</option>
            <option value="other">Other / Not Sure</option>
          </select>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-xs tracking-[2px] uppercase text-earth mb-2 font-body" for="date">
              Preferred Date
            </label>
            <input
              type="date" id="date" name="date"
              class="w-full bg-cream border border-mist rounded-xl px-4 py-3 text-sm text-bark focus:outline-none focus:border-sage transition-colors"
            />
          </div>
          <div>
            <label class="block text-xs tracking-[2px] uppercase text-earth mb-2 font-body" for="time">
              Preferred Time
            </label>
            <input
              type="time" id="time" name="time"
              class="w-full bg-cream border border-mist rounded-xl px-4 py-3 text-sm text-bark focus:outline-none focus:border-sage transition-colors"
            />
          </div>
        </div>

        <div>
          <label class="block text-xs tracking-[2px] uppercase text-earth mb-2 font-body" for="duration">
            Session Length
          </label>
          <select
            id="duration" name="duration"
            class="w-full bg-cream border border-mist rounded-xl px-4 py-3 text-sm text-bark focus:outline-none focus:border-sage transition-colors appearance-none"
          >
            <option value="">Select length...</option>
            <option value="30min">30 minutes</option>
            <option value="1hr">1 hour</option>
            <option value="2hr">2 hours</option>
            <option value="half-day">Half day (4 hours)</option>
            <option value="full-day">Full day (8 hours)</option>
            <option value="custom">Custom / TBD</option>
          </select>
        </div>

        <div>
          <label class="block text-xs tracking-[2px] uppercase text-earth mb-2 font-body" for="format">
            Session Format
          </label>
          <select
            id="format" name="format"
            class="w-full bg-cream border border-mist rounded-xl px-4 py-3 text-sm text-bark focus:outline-none focus:border-sage transition-colors appearance-none"
          >
            <option value="">Select format...</option>
            <option value="virtual">Virtual (Video or Phone)</option>
            <option value="in-person">In-Person (On-Site)</option>
          </select>
        </div>

        <!-- Virtual: optional meeting link -->
        <div id="virtual-fields" class="hidden">
          <label class="block text-xs tracking-[2px] uppercase text-earth mb-2 font-body" for="meeting-url">
            Meeting Link (optional)
          </label>
          <input
            type="url" id="meeting-url" name="meeting_url"
            class="w-full bg-cream border border-mist rounded-xl px-4 py-3 text-sm text-bark placeholder-bark/40 focus:outline-none focus:border-sage transition-colors"
            placeholder="https://zoom.us/j/... or Teams link"
          />
        </div>

        <!-- In-person: requester's location -->
        <div id="in-person-fields" class="hidden">
          <label class="block text-xs tracking-[2px] uppercase text-earth mb-2 font-body" for="location">
            Appointment Address *
          </label>
          <input
            type="text" id="location" name="location"
            class="w-full bg-cream border border-mist rounded-xl px-4 py-3 text-sm text-bark placeholder-bark/40 focus:outline-none focus:border-sage transition-colors"
            placeholder="123 Medical Center Dr, Walnut Creek, CA"
          />
        </div>

        <div>
          <label class="block text-xs tracking-[2px] uppercase text-earth mb-2 font-body" for="message">
            Additional Notes
          </label>
          <textarea
            id="message" name="message" rows="4"
            class="w-full bg-cream border border-mist rounded-xl px-4 py-3 text-sm text-bark placeholder-bark/40 focus:outline-none focus:border-sage transition-colors resize-none"
            placeholder="Any details about the appointment, patient needs, or questions you have..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-clay text-white font-medium py-4 rounded-full hover:bg-earth transition-colors text-sm tracking-wide">
          Request a Booking →
        </button>

        <p class="text-xs text-bark/40 text-center">
          Michelle will confirm availability within one business day.
        </p>
      </form>
    </div>

    <!-- Info -->
    <div class="space-y-10">
      <div>
        <h2 class="font-display text-2xl text-deep-forest mb-6">Contact Information</h2>
        <div class="space-y-4">
          <div class="flex gap-4 items-start">
            <span class="text-xl mt-0.5">📞</span>
            <div>
              <p class="font-medium text-deep-forest text-sm mb-1">Phone</p>
              <p class="text-bark/70 text-sm">(555) 000-0000</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <span class="text-xl mt-0.5">✉️</span>
            <div>
              <p class="font-medium text-deep-forest text-sm mb-1">Email</p>
              <p class="text-bark/70 text-sm">hello@mivozinterpreting.com</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <span class="text-xl mt-0.5">📍</span>
            <div>
              <p class="font-medium text-deep-forest text-sm mb-1">Service Area</p>
              <p class="text-bark/70 text-sm leading-relaxed">
                On-site interpreting in Walnut Creek, CA and throughout the Diablo Valley.<br/>
                Video and phone interpreting available anywhere in the US.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-cream rounded-2xl p-6 border border-mist">
        <h3 class="font-medium text-deep-forest mb-3">What to expect</h3>
        <ul class="space-y-3">
          {[
            'Confirmation within 1 business day',
            'No obligation to book after inquiry',
            'Custom quotes for regular partnerships',
            'Simple onboarding for healthcare organizations',
          ].map(item => (
            <li class="flex items-center gap-3 text-sm text-bark/70">
              <span class="text-clay flex-shrink-0">→</span> {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="border-l-4 border-clay pl-6">
        <p class="font-display italic text-lg text-forest leading-relaxed">
          "Every patient deserves to be heard — and every provider deserves an interpreter
          who shows up prepared and committed."
        </p>
        <p class="text-sm text-earth mt-3">— Michelle</p>
      </div>
    </div>
  </section>

</Layout>

<script>
  const formatSelect = document.getElementById('format') as HTMLSelectElement;
  const virtualFields = document.getElementById('virtual-fields') as HTMLElement;
  const inPersonFields = document.getElementById('in-person-fields') as HTMLElement;
  const locationInput = document.getElementById('location') as HTMLInputElement;

  formatSelect.addEventListener('change', () => {
    const val = formatSelect.value;
    virtualFields.classList.toggle('hidden', val !== 'virtual');
    inPersonFields.classList.toggle('hidden', val !== 'in-person');
    if (val === 'in-person') {
      locationInput.setAttribute('required', '');
    } else {
      locationInput.removeAttribute('required');
    }
  });
</script>
