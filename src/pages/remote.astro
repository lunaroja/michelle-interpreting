---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Remote Interpreting (Video & Phone) — Spanish Medical Interpreter, Nationwide"
  description="Certified Spanish remote medical interpreter (video & phone) available across California and the US. $80/hr, 15-min increments. CMI certified, HIPAA-compliant. Behavioral health specialty.">

  <!-- HERO -->
  <section class="bg-deep-forest py-24 relative overflow-hidden">
    <div class="absolute inset-0 opacity-20"
         style="background: radial-gradient(ellipse at 70% 30%, #7A9E7E 0%, transparent 60%), radial-gradient(ellipse at 10% 80%, #C4956A 0%, transparent 50%);">
    </div>
    <div class="relative max-w-6xl mx-auto px-6 lg:grid lg:grid-cols-2 lg:items-center lg:gap-12">
      <div class="min-w-0">
        <p class="text-xs tracking-[4px] uppercase text-clay mb-4 font-body">Video & Phone · Available Nationwide</p>
        <h1 class="font-display text-5xl md:text-6xl text-cream mb-6 leading-tight max-w-2xl">
          Spanish medical interpreting<br/>
          <span class="italic text-clay">in <span
            id="hero-location"
            data-locations='["Fresno","Stockton","Modesto","Merced","Bakersfield","the Central Valley","Oakland","Los Angeles","California","all 50 states"]'
            style="transition: opacity 0.35s ease-in-out;"
          >Fresno</span>.</span>
        </h1>
        <p class="text-mist/80 max-w-xl leading-relaxed mb-8 text-lg">
          Certified video and phone interpreting for clinics, health systems, FQHCs, and
          behavioral health programs — across California and all 50 states.
          One dedicated interpreter. $80/hour.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact"
             class="inline-block bg-clay text-white font-medium px-8 py-4 rounded-full hover:bg-earth transition-colors">
            Book Remote Interpreting →
          </a>
          <a href="/in-person"
             class="inline-block border border-mist/40 text-mist font-medium px-8 py-4 rounded-full hover:border-clay hover:text-clay transition-colors">
            Need In-Person Interpreting Instead?
          </a>
        </div>
      </div>
      <div class="hidden lg:flex lg:items-center lg:justify-center">
        <img src="/images/remote-illustration.svg" alt="" aria-hidden="true"
             class="w-full max-w-xs opacity-[0.65] pointer-events-none select-none" />
      </div>
    </div>
  </section>

  <!-- PRICING + MODALITIES -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <p class="text-xs tracking-[4px] uppercase text-earth mb-4 font-body">How It Works</p>
    <h2 class="font-display text-3xl md:text-4xl text-deep-forest mb-12">
      Two ways to connect. <span class="italic">One certified interpreter.</span>
    </h2>
    <div class="grid md:grid-cols-2 gap-8 mb-16">

      <div class="bg-white rounded-2xl p-8 border border-mist shadow-sm flex flex-col">
        <div class="text-3xl mb-4">🎥</div>
        <h3 class="font-display text-xl text-deep-forest mb-1">Video Remote Interpreting</h3>
        <p class="text-xs text-earth tracking-wide mb-5">VRI · Zoom, Teams, Doxy.me & more</p>
        <div class="mb-1">
          <span class="font-display text-4xl text-deep-forest">$80</span>
          <span class="text-bark/60 text-sm">/hour</span>
        </div>
        <p class="text-xs text-bark/50 mb-6">Billed in 15-minute increments ($20 per 15 min)</p>
        <ul class="space-y-2 mb-8 flex-1">
          {[
            'Telehealth-ready — works on any video platform',
            'Preserves visual connection for sensitive appointments',
            'Ideal for behavioral health, therapy, and psychiatry',
            'Scheduled sessions and recurring arrangements available',
          ].map(f => (
            <li class="flex items-start gap-3 text-sm text-bark/70">
              <span class="text-clay mt-0.5 flex-shrink-0">✓</span> {f}
            </li>
          ))}
        </ul>
        <a href="/contact"
           class="inline-block w-full text-center bg-deep-forest text-cream text-sm font-medium px-5 py-3 rounded-full hover:bg-forest transition-colors">
          Book Video Session →
        </a>
      </div>

      <div class="bg-white rounded-2xl p-8 border border-mist shadow-sm flex flex-col">
        <div class="text-3xl mb-4">📞</div>
        <h3 class="font-display text-xl text-deep-forest mb-1">Phone Interpreting</h3>
        <p class="text-xs text-earth tracking-wide mb-5">OPI · Immediate & scheduled calls</p>
        <div class="mb-1">
          <span class="font-display text-4xl text-deep-forest">$80</span>
          <span class="text-bark/60 text-sm">/hour</span>
        </div>
        <p class="text-xs text-bark/50 mb-6">Billed in 15-minute increments ($20 per 15 min)</p>
        <ul class="space-y-2 mb-8 flex-1">
          {[
            'Fast access when video isn\'t available or needed',
            'Ideal for follow-up calls, triage, and prescription questions',
            'Pre-scheduled appointments and urgent access',
            'Works for any phone-based clinical workflow',
          ].map(f => (
            <li class="flex items-start gap-3 text-sm text-bark/70">
              <span class="text-clay mt-0.5 flex-shrink-0">✓</span> {f}
            </li>
          ))}
        </ul>
        <a href="/contact"
           class="inline-block w-full text-center bg-deep-forest text-cream text-sm font-medium px-5 py-3 rounded-full hover:bg-forest transition-colors">
          Book Phone Session →
        </a>
      </div>

    </div>

    <div class="bg-deep-forest/5 border border-mist rounded-2xl p-6 text-center max-w-2xl mx-auto">
      <p class="text-sm text-bark/70 leading-relaxed">
        <span class="font-medium text-deep-forest">$80/hour</span>, billed in 15-minute increments — flat-rate, transparent pricing
        built for the way independent clinics and community health organizations actually work.
      </p>
    </div>
  </section>

  <!-- USE CASES -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <p class="text-xs tracking-[4px] uppercase text-earth mb-4 font-body text-center">Common Remote Settings</p>
    <h2 class="font-display text-3xl text-deep-forest text-center mb-4">
      Where remote interpreting <span class="italic">works best</span>
    </h2>
    <p class="text-bark/70 text-center mb-14 max-w-xl mx-auto text-sm leading-relaxed">
      Remote is the right choice when access, speed, or geography are the constraint —
      and when a skilled, certified interpreter can make a full difference over video or phone.
    </p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {[
        { icon: '🧠', title: 'Telehealth Behavioral Health', desc: 'Therapy, psychiatry, and counseling sessions delivered via video — where Michelle\'s specialty shines.' },
        { icon: '💊', title: 'Medication Consultations', desc: 'Pharmacy counseling, medication management, and adherence discussions by phone or video.' },
        { icon: '📋', title: 'Follow-Up Appointments', desc: 'Post-visit check-ins, lab result reviews, and care plan updates.' },
        { icon: '🌿', title: 'Substance Use & Recovery', desc: 'Remote intake, treatment planning, and ongoing support for patients in recovery programs.' },
        { icon: '🏥', title: 'Multi-Site Health Systems', desc: 'Consistent interpreter access across multiple clinic locations without travel constraints.' },
        { icon: '🆘', title: 'Urgent Calls & Triage', desc: 'Fast phone access for urgent clinical questions, prescription calls, and after-hours triage.' },
        { icon: '👥', title: 'Rural & Underserved Clinics', desc: 'Certified interpreting for communities where qualified Spanish interpreters are scarce in person.' },
        { icon: '🌐', title: 'Nationwide Organizations', desc: 'Health systems, national nonprofits, and multi-state programs that need one reliable interpreter.' },
      ].map(i => (
        <div class="bg-cream rounded-2xl p-6 border border-mist shadow-sm">
          <div class="text-3xl mb-4">{i.icon}</div>
          <h3 class="font-medium text-deep-forest text-sm mb-2">{i.title}</h3>
          <p class="text-xs text-bark/60 leading-relaxed">{i.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- WHERE WE SERVE -->
  <section class="bg-cream py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs tracking-[4px] uppercase text-earth mb-4 font-body">Service Reach</p>
      <h2 class="font-display text-3xl md:text-4xl text-deep-forest mb-6">
        California-rooted. <span class="italic">Nationally available.</span>
      </h2>
      <p class="text-bark/70 leading-relaxed mb-14 max-w-2xl text-sm">
        Remote interpreting has no geographic limit. Michelle serves healthcare organizations
        across all 50 states, with a particular focus on California's most underserved communities —
        the Central Valley, rural areas, and communities where certified Spanish interpreting is hardest to find.
      </p>

      <div class="grid md:grid-cols-2 gap-8 mb-10">

        <div>
          <p class="text-xs tracking-[3px] uppercase text-clay font-body mb-6">California Focus Areas</p>
          <div class="space-y-5">
            {[
              {
                region: 'Central Valley',
                desc: 'One of California\'s largest Spanish-speaking populations — and one of the most underserved medical interpreting markets. Mi Voz serves Fresno, Stockton, Modesto, Merced, Visalia, Bakersfield, and surrounding communities.',
                cities: ['Fresno', 'Stockton', 'Modesto', 'Merced', 'Visalia', 'Bakersfield'],
              },
              {
                region: 'Bay Area & East Bay',
                desc: 'Remote sessions for Bay Area providers who need flexible coverage — or who want to keep a dedicated interpreter for telehealth visits.',
                cities: ['Oakland', 'San Jose', 'San Francisco', 'Richmond', 'Fremont'],
              },
              {
                region: 'Inland Empire & Southern CA',
                desc: 'Video and phone interpreting for clinics and health systems throughout Southern California.',
                cities: ['Los Angeles', 'Riverside', 'San Bernardino', 'Bakersfield'],
              },
            ].map(r => (
              <div class="bg-white rounded-2xl p-6 border border-mist">
                <h3 class="font-display text-lg text-deep-forest mb-2">{r.region}</h3>
                <p class="text-xs text-bark/60 leading-relaxed mb-4">{r.desc}</p>
                <div class="flex flex-wrap gap-2">
                  {r.cities.map(c => (
                    <span class="text-xs font-medium bg-mist/60 text-deep-forest px-3 py-1 rounded-full border border-mist">{c}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div>
          <p class="text-xs tracking-[3px] uppercase text-clay font-body mb-6">Nationwide</p>
          <div class="bg-white rounded-2xl p-8 border border-mist h-full flex flex-col justify-between">
            <div>
              <h3 class="font-display text-2xl text-deep-forest mb-4">All 50 States</h3>
              <p class="text-sm text-bark/70 leading-relaxed mb-6">
                Remote interpreting works everywhere there's an internet connection or a phone signal.
                Mi Voz has served providers in California, Nevada, Texas, Oregon, Washington, Arizona,
                and beyond.
              </p>
              <p class="text-sm text-bark/70 leading-relaxed mb-6">
                Whether you're a national health system needing a dedicated Spanish interpreter or a
                small rural clinic with limited access to certified professionals — remote services make
                Mi Voz available to you.
              </p>
              <div class="flex flex-wrap gap-2 mb-6">
                {['California', 'Nevada', 'Oregon', 'Washington', 'Arizona', 'Texas', 'New Mexico', 'All 50 States'].map(s => (
                  <span class="text-xs font-medium bg-mist/60 text-deep-forest px-3 py-1 rounded-full border border-mist">{s}</span>
                ))}
              </div>
            </div>
            <a href="/contact"
               class="inline-block text-center bg-clay text-white text-sm font-medium px-6 py-3 rounded-full hover:bg-earth transition-colors">
              Request Remote Interpreting →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY MI VOZ REMOTE -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-xs tracking-[4px] uppercase text-earth mb-4 font-body">Why Mi Voz</p>
        <h2 class="font-display text-3xl text-deep-forest mb-6 leading-snug">
          Not a platform.<br/>
          <span class="italic text-clay">A dedicated partner.</span>
        </h2>
        <p class="text-bark/70 leading-relaxed mb-4 text-sm">
          For independent clinics, FQHCs, and behavioral health programs, continuity of care in
          interpreting is as important as it is in any other part of care. When the same interpreter
          shows up to every session, they learn your patients, your clinical context, and the
          nuances of your practice — and every session benefits from that accumulated trust.
        </p>
        <p class="text-bark/70 leading-relaxed mb-4 text-sm">
          With Mi Voz, you work with Michelle — consistently. Over time, that familiarity improves
          the quality and depth of every session.
        </p>
        <p class="text-bark/70 leading-relaxed mb-8 text-sm">
          For FQHCs and nonprofits serving underserved communities, Mi Voz offers flexible
          arrangements that reflect the mission-driven nature of the work.
        </p>
        <a href="/contact" class="inline-block bg-clay text-white font-medium px-7 py-3 rounded-full hover:bg-earth transition-colors">
          Talk to Michelle →
        </a>
      </div>
      <div class="space-y-4">
        {[
          { title: 'CMI Certified', desc: 'Nationally certified with formal medical interpreting training and deep fluency in clinical and behavioral health terminology.' },
          { title: 'Behavioral Health Specialty', desc: 'Therapy, psychiatry, substance use, and crisis — a rare specialty among remote interpreters.' },
          { title: 'HIPAA Compliant', desc: 'Full patient privacy commitment in every remote session, on every platform.' },
          { title: 'Telehealth Ready', desc: 'Works on Zoom, Teams, Doxy.me, or any video platform your clinic already uses.' },
          { title: 'Transparent Pricing', desc: '$80/hour billed in 15-minute increments. Flat-rate, no hidden fees, no billing surprises.' },
          { title: 'Same Interpreter Every Time', desc: 'No random assignment. Michelle is your interpreter — every session.' },
        ].map(i => (
          <div class="flex items-start gap-4">
            <span class="text-clay font-bold mt-0.5 flex-shrink-0">✓</span>
            <div>
              <h3 class="font-medium text-deep-forest text-sm mb-1">{i.title}</h3>
              <p class="text-xs text-bark/60 leading-relaxed">{i.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 py-20 text-center">
    <h2 class="font-display text-3xl md:text-4xl text-deep-forest mb-4">
      Certified remote interpreting,<br/>
      <span class="italic text-clay">wherever you are.</span>
    </h2>
    <p class="text-bark/70 mb-8 text-sm leading-relaxed max-w-md mx-auto">
      Book a single session or discuss a recurring arrangement. Michelle will confirm
      availability within one business day.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/contact" class="inline-block bg-clay text-white font-medium px-8 py-4 rounded-full hover:bg-earth transition-colors">
        Book Remote Interpreting →
      </a>
      <a href="/providers" class="inline-block border border-forest text-forest font-medium px-8 py-4 rounded-full hover:bg-forest hover:text-cream transition-colors">
        Provider Information
      </a>
    </div>
  </section>

</Layout>

<script>
  const el = document.getElementById('hero-location');
  if (el) {
    const locations = JSON.parse(el.dataset.locations!);
    let idx = 0;
    setInterval(() => {
      el.style.opacity = '0';
      setTimeout(() => {
        idx = (idx + 1) % locations.length;
        el.textContent = locations[idx];
        el.style.opacity = '1';
      }, 350);
    }, 2000);
  }
</script>
