---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home" description="Mi Voz Interpreting — Certified Spanish medical interpreter in Walnut Creek, CA. Behavioral health specialty. On-site Diablo Valley, VRI & OPI nationwide. HIPAA-compliant. CMI certified.">

  <!-- HERO -->
  <section class="bg-deep-forest relative overflow-hidden">
    <div class="absolute inset-0 opacity-20"
         style="background: radial-gradient(ellipse at 80% 20%, #7A9E7E 0%, transparent 60%), radial-gradient(ellipse at 10% 80%, #C4956A 0%, transparent 50%);">
    </div>
    <div class="relative max-w-6xl mx-auto px-6 py-28 md:py-36">
      <p class="text-xs tracking-[4px] uppercase text-clay mb-6 font-body">Spanish Medical Interpreting</p>
      <h1 class="font-display text-5xl md:text-7xl text-cream leading-tight mb-6 max-w-2xl">
        Your voice.<br/>
        <span class="italic text-clay">Their care.</span>
      </h1>
      <p class="text-lg text-mist/80 max-w-xl leading-relaxed mb-10 font-body">
        Every patient deserves to be fully heard. Mi Voz provides certified, HIPAA-compliant
        Spanish interpreting for healthcare providers — on-site, video, and phone.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/providers"
           class="bg-clay text-white font-medium px-7 py-3.5 rounded-full hover:bg-earth transition-colors text-center">
          I'm a Healthcare Provider
        </a>
        <a href="/contact"
           class="border border-mist/40 text-mist font-medium px-7 py-3.5 rounded-full hover:border-clay hover:text-clay transition-colors text-center">
          Book a Session
        </a>
      </div>
    </div>
  </section>

  <!-- DUAL AUDIENCE CTA -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <p class="text-xs tracking-[4px] uppercase text-earth text-center mb-12 font-body">Who We Serve</p>
    <div class="grid md:grid-cols-2 gap-6">

      <!-- Providers -->
      <div class="bg-deep-forest rounded-2xl p-8 md:p-10">
        <p class="text-xs tracking-[3px] uppercase text-clay mb-4">For Hospitals, Clinics & Agencies</p>
        <h2 class="font-display text-2xl text-cream mb-4 leading-snug">
          Certified. Compliant.<br/>Cost-effective.
        </h2>
        <p class="text-sm text-mist/80 leading-relaxed mb-6">
          Agency-trained expertise at independent pricing. HIPAA-compliant, professionally
          certified, and dedicated — not dispatched randomly. Meet your language access
          obligations with a partner who knows your practice.
        </p>
        <ul class="space-y-2 mb-8">
          {['HIPAA-compliant & certified', 'On-site, video & phone available', 'Lower rates than large agencies', 'One dedicated interpreter'].map(item => (
            <li class="flex items-center gap-3 text-sm text-mist/70">
              <span class="text-clay">→</span> {item}
            </li>
          ))}
        </ul>
        <a href="/providers"
           class="inline-block bg-clay text-white text-sm font-medium px-6 py-3 rounded-full hover:bg-earth transition-colors">
          Learn More →
        </a>
      </div>

      <!-- Patients -->
      <div class="bg-cream rounded-2xl p-8 md:p-10 border border-mist">
        <p class="text-xs tracking-[3px] uppercase text-earth mb-4">For Patients & Families</p>
        <h2 class="font-display text-2xl text-deep-forest mb-4 leading-snug">
          You deserve to<br/>
          <span class="italic">be understood.</span>
        </h2>
        <p class="text-sm text-bark leading-relaxed mb-6">
          Being sick is hard enough. Not being understood makes it harder. Mi Voz ensures
          Spanish-speaking patients can ask questions, understand diagnoses, and make informed
          decisions about their own care.
        </p>
        <ul class="space-y-2 mb-8">
          {['Compassionate, patient-centered', 'Medical terminology you can trust', 'A voice when you need one most', 'Available on-site & remotely'].map(item => (
            <li class="flex items-center gap-3 text-sm text-bark/70">
              <span class="text-clay">→</span> {item}
            </li>
          ))}
        </ul>
        <a href="/contact"
           class="inline-block bg-forest text-cream text-sm font-medium px-6 py-3 rounded-full hover:bg-deep-forest transition-colors">
          Find Support →
        </a>
      </div>
    </div>
  </section>

  <!-- SERVICES OVERVIEW -->
  <section class="bg-cream py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs tracking-[4px] uppercase text-earth text-center mb-4 font-body">What We Offer</p>
      <h2 class="font-display text-3xl md:text-4xl text-deep-forest text-center mb-14">
        Interpreting that <span class="italic">fits your needs</span>
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: '🏥', title: 'On-Site Interpreting', desc: 'In-person at your clinic, hospital, or office. The most personal connection between provider and patient.' },
          { icon: '🎥', title: 'Video Interpreting', desc: 'High-quality video remote interpreting for telehealth visits and virtual appointments.' },
          { icon: '📞', title: 'Phone Interpreting', desc: 'Immediate access by phone — ideal for urgent situations or when video isn\'t available.' },
          { icon: '📄', title: 'Document Translation', desc: 'Accurate Spanish translation of medical records, consent forms, discharge instructions, and more.' },
        ].map(s => (
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-mist/60 hover:shadow-md transition-shadow">
            <div class="text-3xl mb-4">{s.icon}</div>
            <h3 class="font-display text-lg text-deep-forest mb-3">{s.title}</h3>
            <p class="text-sm text-bark/70 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/services"
           class="inline-block border border-forest text-forest text-sm font-medium px-7 py-3 rounded-full hover:bg-forest hover:text-cream transition-colors">
          View All Services →
        </a>
      </div>
    </div>
  </section>

  <!-- WHY MI VOZ -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <p class="text-xs tracking-[4px] uppercase text-earth mb-4 font-body">Why Mi Voz</p>
    <h2 class="font-display text-3xl md:text-4xl text-deep-forest mb-14 max-w-xl">
      The personal difference <span class="italic">agencies can't offer</span>
    </h2>
    <div class="grid md:grid-cols-2 gap-x-16 gap-y-10">
      {[
        { num: '13+', title: 'Years of Professional Experience', desc: 'Over a decade serving major health systems including UCSF Health, John Muir Health, Kaiser Permanente, and community nonprofits across the Bay Area.' },
        { num: 'CMI', title: 'Certified Medical Interpreter', desc: 'Nationally certified with deep expertise in behavioral health, medical terminology, and HIPAA-compliant practice.' },
        { num: '01', title: 'One Dedicated Interpreter', desc: 'No random dispatch. Healthcare organizations work with the same interpreter who learns the rhythms of their practice.' },
        { num: '02', title: 'Mission-Driven', desc: 'Michelle believes every patient deserves a voice. That purpose shows up in every single session — for patients and providers alike.' },
      ].map(d => (
        <div class="flex gap-5">
          <span class="font-display text-4xl text-mist leading-none mt-1 min-w-[2.5rem]">{d.num}</span>
          <div>
            <h3 class="font-body font-medium text-deep-forest mb-2">{d.title}</h3>
            <p class="text-sm text-bark/70 leading-relaxed">{d.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ABOUT TEASER -->
  <section class="bg-deep-forest py-20">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-xs tracking-[4px] uppercase text-clay mb-4 font-body">About Michelle</p>
        <h2 class="font-display text-3xl md:text-4xl text-cream mb-6 leading-snug">
          Giving patients<br/>
          <span class="italic text-clay">their voice back.</span>
        </h2>
        <p class="text-mist/80 leading-relaxed mb-4 text-sm">
          "Mi Voz" means "My Voice." It's the voice Michelle lends to patients who can't advocate
          for themselves — a bridge between who they are and the care they deserve.
        </p>
        <p class="text-mist/80 leading-relaxed mb-8 text-sm">
          With over 13 years of experience, Michelle has worked with UCSF Health, John Muir Health,
          Kaiser Permanente, and community nonprofits across the Bay Area — with a specialty focus in
          behavioral health interpreting.
        </p>
        <a href="/about"
           class="inline-block border border-clay text-clay text-sm font-medium px-6 py-3 rounded-full hover:bg-clay hover:text-white transition-colors">
          Meet Michelle →
        </a>
      </div>
      <img src="/images/michelle-headshot-square.jpg"
           alt="Michelle, Certified Medical Interpreter and founder of Mi Voz Interpreting"
           class="rounded-2xl aspect-square object-cover w-full" />
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <p class="text-xs tracking-[4px] uppercase text-earth text-center mb-4 font-body">Client Voices</p>
    <h2 class="font-display text-3xl md:text-4xl text-deep-forest text-center mb-14">
      What healthcare providers <span class="italic">are saying</span>
    </h2>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        {
          quote: "Having the same interpreter who knows our clinic workflow has been transformative. Our Spanish-speaking patients are more engaged and our providers feel confident that nothing gets lost.",
          name: "Clinic Director",
          org: "Bay Area Health System",
          initials: "CD"
        },
        {
          quote: "Michelle's behavioral health interpreting is exceptional — she understands the sensitivity these sessions require. Our therapy clients trust her, and that trust makes all the difference.",
          name: "Clinical Supervisor",
          org: "Behavioral Health Program",
          initials: "CS"
        },
        {
          quote: "We switched from a large agency to Mi Voz and the difference is night and day. More personal, more reliable, and our patients actually recognize the interpreter now.",
          name: "Practice Manager",
          org: "Community Health Clinic",
          initials: "PM"
        }
      ].map(t => (
        <div class="bg-cream rounded-2xl p-8 border border-mist flex flex-col">
          <div class="text-clay text-3xl font-display leading-none mb-4">"</div>
          <p class="text-sm text-bark/80 leading-relaxed flex-1 italic mb-6">{t.quote}</p>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-forest/20 border border-forest/30 flex items-center justify-center text-xs font-medium text-forest">
              {t.initials}
            </div>
            <div>
              <p class="text-sm font-medium text-deep-forest leading-tight">{t.name}</p>
              <p class="text-xs text-earth">{t.org}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- TRUSTED BY -->
  <section class="bg-cream py-14">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-xs tracking-[4px] uppercase text-earth mb-8 font-body">Trusted by Leading Healthcare Organizations</p>
      <div class="flex flex-wrap justify-center items-center gap-6 md:gap-12">
        {['UCSF Health', 'John Muir Health', 'Kaiser Permanente', 'RotaCare Bay Area'].map(org => (
          <span class="font-display text-lg text-deep-forest/50 hover:text-deep-forest transition-colors">{org}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- PULL QUOTE -->
  <section class="bg-cream py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <blockquote class="font-display italic text-2xl md:text-3xl text-forest leading-relaxed mb-6">
        "Language should never stand between a patient and their care."
      </blockquote>
      <p class="text-sm text-earth font-body">— Michelle, Founder of Mi Voz Interpreting</p>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="max-w-6xl mx-auto px-6 py-20 text-center">
    <h2 class="font-display text-3xl md:text-4xl text-deep-forest mb-4">
      Ready to work <span class="italic text-clay">together?</span>
    </h2>
    <p class="text-bark/70 mb-8 max-w-md mx-auto leading-relaxed">
      Whether you're a healthcare provider looking for a reliable interpreter or a patient who
      needs support — Mi Voz is here.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/contact"
         class="bg-clay text-white font-medium px-8 py-4 rounded-full hover:bg-earth transition-colors">
        Book a Session
      </a>
      <a href="/providers"
         class="border border-forest text-forest font-medium px-8 py-4 rounded-full hover:bg-forest hover:text-cream transition-colors">
        Provider Inquiry
      </a>
    </div>
  </section>

</Layout>
