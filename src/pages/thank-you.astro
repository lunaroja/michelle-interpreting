---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Thank You" description="Thank you for reaching out to Mi Voz Interpreting." noindex={true}>
  <section class="min-h-[70vh] flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <div class="text-5xl mb-6">🌿</div>
      <h1 class="font-display text-3xl text-deep-forest mb-4">
        Thank you for reaching out!
      </h1>
      <p class="text-bark/70 leading-relaxed mb-8">
        Michelle will get back to you within one business day. We look forward to
        working together to serve your patients.
      </p>
      <a href="/" class="inline-block bg-clay text-white font-medium px-7 py-3 rounded-full hover:bg-earth transition-colors">
        Back to Home
      </a>
    </div>
  </section>
</Layout>
