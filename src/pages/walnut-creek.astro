---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Spanish Medical Interpreter — Walnut Creek & Diablo Valley"
  description="Certified Spanish medical interpreter in Walnut Creek, CA. On-site interpreting in Concord, Pleasant Hill, Martinez, Antioch, and the Diablo Valley. CMI certified, behavioral health specialty, HIPAA-compliant.">

  <!-- HERO -->
  <section class="bg-deep-forest py-24 relative overflow-hidden">
    <div class="absolute inset-0 opacity-20"
         style="background: radial-gradient(ellipse at 80% 20%, #7A9E7E 0%, transparent 60%);">
    </div>
    <div class="relative max-w-6xl mx-auto px-6">
      <p class="text-xs tracking-[4px] uppercase text-clay mb-4 font-body">Walnut Creek & Diablo Valley</p>
      <h1 class="font-display text-5xl md:text-6xl text-cream mb-6 leading-tight max-w-2xl">
        Spanish medical interpreter<br/>
        <span class="italic text-clay">in Walnut Creek, CA.</span>
      </h1>
      <p class="text-mist/80 max-w-xl leading-relaxed mb-8 text-lg">
        Certified, in-person Spanish medical interpreting across the Diablo Valley.
        Available on-site at clinics, hospitals, and offices in Walnut Creek, Concord,
        Pleasant Hill, Martinez, and surrounding communities.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact"
           class="inline-block bg-clay text-white font-medium px-8 py-4 rounded-full hover:bg-earth transition-colors">
          Book On-Site Interpreting →
        </a>
        <a href="/about"
           class="inline-block border border-mist/40 text-mist font-medium px-8 py-4 rounded-full hover:border-clay hover:text-clay transition-colors">
          Meet Michelle
        </a>
      </div>
    </div>
  </section>

  <!-- LOCAL INTRO -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-xs tracking-[4px] uppercase text-earth mb-4 font-body">Local & Certified</p>
        <h2 class="font-display text-3xl md:text-4xl text-deep-forest mb-6 leading-snug">
          Walnut Creek's dedicated<br/>
          <span class="italic">Spanish medical interpreter.</span>
        </h2>
        <p class="text-bark/70 leading-relaxed mb-4 text-sm">
          Michelle is a Walnut Creek-based Certified Medical Interpreter (CMI) with 13+ years of
          experience serving major health systems including John Muir Health, UCSF Health, and
          Kaiser Permanente throughout Contra Costa County.
        </p>
        <p class="text-bark/70 leading-relaxed mb-4 text-sm">
          Unlike national platforms that send a different interpreter every time, Mi Voz provides
          one dedicated professional who learns the rhythm of your practice, your patient population,
          and your clinical context.
        </p>
        <p class="text-bark/70 leading-relaxed mb-8 text-sm">
          For healthcare providers in Walnut Creek and the Diablo Valley, that continuity makes
          a measurable difference in care quality.
        </p>
        <a href="/providers" class="inline-block bg-forest text-cream font-medium px-7 py-3 rounded-full hover:bg-deep-forest transition-colors">
          Provider Information →
        </a>
      </div>
      <div class="space-y-4">
        <div class="bg-cream rounded-2xl p-8 border border-mist">
          <h3 class="font-body font-medium text-deep-forest text-sm uppercase tracking-widest mb-5">On-Site Service Area</h3>
          <div class="flex flex-wrap gap-2">
            {['Walnut Creek', 'Concord', 'Pleasant Hill', 'Martinez', 'Antioch', 'Brentwood', 'Pittsburg', 'Orinda', 'Lafayette', 'Moraga', 'Bay Area'].map(city => (
              <span class="text-xs font-medium bg-mist text-deep-forest px-3 py-1.5 rounded-full border border-mist">{city}</span>
            ))}
          </div>
        </div>
        <div class="grid grid-cols-3 gap-4">
          {[
            ['13+', 'Years experience'],
            ['CMI', 'Certified'],
            ['100%', 'HIPAA compliant'],
          ].map(([val, label]) => (
            <div class="bg-cream rounded-xl p-5 border border-mist text-center">
              <p class="font-display text-2xl text-clay leading-none mb-1">{val}</p>
              <p class="text-xs text-earth tracking-wide">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="bg-cream py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs tracking-[4px] uppercase text-earth mb-4 font-body text-center">Services in the Diablo Valley</p>
      <h2 class="font-display text-3xl text-deep-forest text-center mb-14">
        Every modality. <span class="italic">One trusted interpreter.</span>
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: '🏥', title: 'On-Site Interpreting', desc: 'In-person at your Walnut Creek clinic or Diablo Valley location — the highest-quality interpreting for sensitive appointments.', link: '/services' },
          { icon: '🎥', title: 'Video Remote (VRI)', desc: 'High-quality video interpreting for telehealth visits — available anywhere your providers and patients are.', link: '/services' },
          { icon: '📞', title: 'Phone Interpreting', desc: 'Fast, accessible OPI for urgent calls, triage, and follow-up appointments.', link: '/services' },
          { icon: '🧠', title: 'Behavioral Health', desc: 'Specialized mental health interpreting for therapy, psychiatry, and crisis settings — a rare specialty in the Bay Area.', link: '/services' },
        ].map(s => (
          <div class="bg-white rounded-2xl p-6 border border-mist shadow-sm">
            <div class="text-3xl mb-4">{s.icon}</div>
            <h3 class="font-display text-lg text-deep-forest mb-3">{s.title}</h3>
            <p class="text-sm text-bark/70 leading-relaxed mb-4">{s.desc}</p>
            <a href={s.link} class="text-xs text-clay hover:underline">Learn more →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPLIANCE -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <p class="text-xs tracking-[4px] uppercase text-earth mb-4 font-body">For Walnut Creek & Contra Costa Providers</p>
    <h2 class="font-display text-3xl text-deep-forest mb-6 max-w-xl">
      Meet your language access obligations —<br/>
      <span class="italic">with a local partner who knows the community.</span>
    </h2>
    <p class="text-bark/70 leading-relaxed mb-10 max-w-2xl text-sm">
      California healthcare providers are required to provide meaningful language access under Title VI
      of the Civil Rights Act, ACA Section 1557, and California state law. Mi Voz provides the certified,
      HIPAA-compliant interpreting your practice needs to meet those obligations — at rates well below
      what large agencies charge.
    </p>
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/contact" class="inline-block bg-clay text-white font-medium px-8 py-4 rounded-full hover:bg-earth transition-colors">
        Book a Session in Walnut Creek →
      </a>
      <a href="/providers" class="inline-block border border-forest text-forest font-medium px-8 py-4 rounded-full hover:bg-forest hover:text-cream transition-colors">
        Provider Inquiry
      </a>
    </div>
  </section>

</Layout>
