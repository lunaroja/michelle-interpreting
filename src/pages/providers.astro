---
import Layout from '../layouts/Layout.astro';
---
<Layout title="For Providers" description="HIPAA-compliant Spanish medical interpreting for hospitals, clinics, agencies and staffing firms. Certified, affordable, dedicated.">

  <!-- HERO -->
  <section class="bg-deep-forest py-24 relative overflow-hidden">
    <div class="absolute inset-0 opacity-20"
         style="background: radial-gradient(ellipse at 80% 30%, #7A9E7E 0%, transparent 55%);">
    </div>
    <div class="relative max-w-6xl mx-auto px-6">
      <p class="text-xs tracking-[4px] uppercase text-clay mb-4 font-body">Healthcare Organizations</p>
      <h1 class="font-display text-5xl text-cream mb-6 max-w-2xl leading-tight">
        The interpreter your patients need.<br/>
        <span class="italic text-clay">The partner your practice deserves.</span>
      </h1>
      <p class="text-mist/80 max-w-xl leading-relaxed mb-8">
        Certified, HIPAA-compliant Spanish interpreting for hospitals, clinics, community health
        centers, agencies, and staffing firms. Agency-trained quality at independent pricing.
      </p>
      <a href="/contact"
         class="inline-block bg-clay text-white font-medium px-8 py-4 rounded-full hover:bg-earth transition-colors">
        Partner With Mi Voz →
      </a>
    </div>
  </section>

  <!-- WHO WE SERVE -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <p class="text-xs tracking-[4px] uppercase text-earth mb-4 font-body">Who We Work With</p>
    <h2 class="font-display text-3xl md:text-4xl text-deep-forest mb-12">
      Built for every type of <span class="italic">healthcare organization</span>
    </h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {[
        { icon: '🏥', title: 'Hospitals & Health Systems', desc: 'Supplement your language access program with a certified, dedicated Spanish interpreter.' },
        { icon: '🩺', title: 'Private Practices & Clinics', desc: 'Affordable professional interpreting that fits smaller budgets without compromising quality.' },
        { icon: '🤝', title: 'Language & Staffing Agencies', desc: 'Subcontract a certified Spanish interpreter to fulfill client placements reliably.' },
        { icon: '🌿', title: 'Community Health Centers', desc: 'Mission-aligned interpreting for FQHCs and nonprofits serving underserved communities.' },
      ].map(c => (
        <div class="bg-cream rounded-2xl p-6 border border-mist">
          <div class="text-3xl mb-4">{c.icon}</div>
          <h3 class="font-body font-medium text-deep-forest mb-2 text-base">{c.title}</h3>
          <p class="text-sm text-bark/70 leading-relaxed">{c.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- COMPLIANCE SECTION -->
  <section class="bg-cream py-20">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-xs tracking-[4px] uppercase text-earth mb-4 font-body">Compliance & Credentials</p>
        <h2 class="font-display text-3xl text-deep-forest mb-6 leading-snug">
          Meet your language access<br/>
          <span class="italic">obligations with confidence.</span>
        </h2>
        <p class="text-bark/70 leading-relaxed mb-4 text-sm">
          Federal law requires healthcare organizations receiving federal funding to provide
          meaningful language access to patients with limited English proficiency (LEP) —
          under Title VI of the Civil Rights Act, Section 1557 of the ACA, and state regulations.
        </p>
        <p class="text-bark/70 leading-relaxed mb-8 text-sm">
          Mi Voz helps you fulfill those obligations with a certified, HIPAA-compliant interpreter
          who understands both the legal requirements and the clinical context.
        </p>
        <a href="/contact" class="inline-block bg-forest text-cream text-sm font-medium px-6 py-3 rounded-full hover:bg-deep-forest transition-colors">
          Discuss Your Needs →
        </a>
      </div>
      <div class="space-y-4">
        {[
          { label: 'HIPAA Compliant', desc: 'Full compliance with patient privacy and data security requirements.' },
          { label: 'Certified Medical Interpreter', desc: 'Professional certification and medical terminology expertise.' },
          { label: 'Title VI & ACA Section 1557', desc: 'Helps fulfill federal language access obligations.' },
          { label: 'Professional Code of Ethics', desc: 'Accuracy, confidentiality, impartiality — always.' },
        ].map(c => (
          <div class="bg-white rounded-xl p-5 border border-mist shadow-sm flex gap-4 items-start">
            <span class="text-clay text-xl mt-0.5">✓</span>
            <div>
              <h3 class="font-medium text-deep-forest text-sm mb-1">{c.label}</h3>
              <p class="text-xs text-bark/60 leading-relaxed">{c.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING ADVANTAGE -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div class="bg-deep-forest rounded-2xl p-10">
        <p class="text-xs tracking-[3px] uppercase text-clay mb-4 font-body">The Mi Voz Difference</p>
        <h3 class="font-display text-2xl text-cream mb-6 leading-snug">
          Agency expertise.<br/>
          <span class="italic text-clay">Independent pricing.</span>
        </h3>
        <p class="text-mist/80 text-sm leading-relaxed mb-6">
          Large agencies charge for overhead, management layers, and dispatcher markups.
          Mi Voz cuts those costs without cutting quality — Michelle trained inside a leading
          Language World agency and brings the same professional standard at a
          rate that makes sense for your budget.
        </p>
        <div class="border-t border-forest/50 pt-6 space-y-3">
          {['No agency overhead or markups', 'Transparent, straightforward pricing', 'Custom arrangements for regular engagements', 'Fair rates for nonprofits & FQHCs'].map(i => (
            <div class="flex items-center gap-3 text-sm text-mist/80">
              <span class="text-clay">→</span> {i}
            </div>
          ))}
        </div>
      </div>
      <div>
        <p class="text-xs tracking-[4px] uppercase text-earth mb-4 font-body">Why One Dedicated Interpreter?</p>
        <h2 class="font-display text-3xl text-deep-forest mb-6">
          Not a <span class="italic">random dispatch.</span>
          <br/>A real partner.
        </h2>
        <p class="text-bark/70 leading-relaxed mb-4 text-sm">
          When you work with a large agency, you get whoever is available. That interpreter doesn't
          know your workflow, your providers, or your patient population.
        </p>
        <p class="text-bark/70 leading-relaxed mb-4 text-sm">
          With Mi Voz, you work with Michelle — consistently. She learns the rhythms of your
          practice, builds rapport with your staff, and delivers interpreting that's more accurate
          because she knows the context.
        </p>
        <p class="text-bark/70 leading-relaxed text-sm">
          For your patients, that consistency matters enormously. A familiar face (or voice) reduces
          anxiety and builds the trust that leads to better health outcomes.
        </p>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="bg-cream py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs tracking-[4px] uppercase text-earth mb-4 font-body text-center">Getting Started</p>
      <h2 class="font-display text-3xl text-deep-forest text-center mb-14">How it works</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { step: '01', title: 'Reach Out', desc: 'Contact us to discuss your organization\'s needs — volume, modalities, scheduling preferences, and budget.' },
          { step: '02', title: 'Custom Agreement', desc: 'We\'ll set up a simple service agreement that covers rates, availability, and preferred booking process.' },
          { step: '03', title: 'Start Serving Patients', desc: 'Book sessions as needed. Michelle shows up prepared, professional, and ready to bridge the language gap.' },
        ].map(s => (
          <div class="text-center">
            <div class="font-display text-5xl text-mist mb-4">{s.step}</div>
            <h3 class="font-medium text-deep-forest mb-3">{s.title}</h3>
            <p class="text-sm text-bark/70 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 py-20 text-center">
    <h2 class="font-display text-3xl text-deep-forest mb-4">Ready to partner with Mi Voz?</h2>
    <p class="text-bark/70 mb-8 max-w-md mx-auto">
      Let's talk about how Mi Voz can serve your patients and your organization.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/contact" class="bg-clay text-white font-medium px-8 py-4 rounded-full hover:bg-earth transition-colors">
        Send an Inquiry
      </a>
      <a href="/services" class="border border-forest text-forest font-medium px-8 py-4 rounded-full hover:bg-forest hover:text-cream transition-colors">
        View Services
      </a>
    </div>
  </section>

</Layout>
