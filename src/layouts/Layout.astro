---
export interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = "Professional Spanish medical interpreting services. In-person, video, and phone. HIPAA-compliant. Serving healthcare providers and patients."
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Mi Voz Interpreting</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={`https://mivozinterpreting.com${Astro.url.pathname}`} />
  <!-- Local Business structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Mi Voz Interpreting",
    "description": "Certified Spanish medical interpreting — in-person, video remote (VRI), and over-the-phone (OPI). Specializing in behavioral health. HIPAA-compliant.",
    "url": "https://mivozinterpreting.com",
    "email": "michelle@mivozinterpreting.com",
    "image": "https://mivozinterpreting.com/og-image.jpg",
    "founder": { "@type": "Person", "name": "Michelle", "jobTitle": "Certified Medical Interpreter (CMI)" },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Walnut Creek",
      "addressRegion": "CA",
      "addressCountry": "US"
    },
    "areaServed": [
      { "@type": "City", "name": "Walnut Creek" },
      { "@type": "City", "name": "Concord" },
      { "@type": "City", "name": "Antioch" },
      { "@type": "City", "name": "Pleasant Hill" },
      { "@type": "City", "name": "Martinez" },
      { "@type": "City", "name": "Fresno" },
      { "@type": "City", "name": "Stockton" },
      { "@type": "AdministrativeArea", "name": "Diablo Valley" },
      { "@type": "AdministrativeArea", "name": "Central Valley, California" }
    ],
    "knowsLanguage": ["en", "es"],
    "hasCredential": [
      { "@type": "EducationalOccupationalCredential", "credentialCategory": "CMI — Certified Medical Interpreter" }
    ],
    "serviceType": ["Medical Interpreting", "Behavioral Health Interpreting", "Document Translation"],
    "priceRange": "$$",
    "sameAs": []
  })} />
</head>
<body class="bg-warm-white font-body text-bark antialiased">

  <!-- HEADER -->
  <header class="bg-deep-forest sticky top-0 z-50 shadow-md">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-baseline gap-1.5 group">
        <svg width="32" height="26" viewBox="0 0 397 323" fill="none" xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0">
          <path d="M164.226 18.279C179.974 30.6528 190.604 45.7832 195.39 65.2204C195.703 68.0559 195.68 70.3745 195.39 73.2204C192.99 70.1905 191.167 67.0522 189.327 63.6579C178.778 45.5923 163.937 36.8428 144.273 31.6628C123.544 26.5901 101.082 31.4424 82.9837 42.2556C71.6177 49.6027 63.0389 58.4555 56.39 70.2204C56.002 70.8856 55.6139 71.5507 55.2142 72.236C45.8374 89.4691 44.7789 111.322 49.7518 130.087C57.9038 157.343 74.5788 179.728 93.7025 200.314C96.1327 202.942 98.5163 205.604 100.89 208.283C107.601 215.751 114.654 222.831 122.296 229.345C124.93 231.704 127.408 234.205 129.89 236.72C132.882 239.753 135.881 242.722 139.14 245.47C148.545 253.512 157.588 262.614 165.39 272.22C166.629 273.719 166.629 273.719 167.894 275.248C177.656 287.229 185.998 300.119 192.39 314.22C192.993 315.529 192.993 315.529 193.609 316.865C194.39 319.22 194.39 319.22 193.39 322.22C192.914 321.6 192.439 320.98 191.949 320.341C182.153 307.949 170.915 296.846 158.39 287.22C157.045 286.17 155.7 285.119 154.355 284.068C147.258 278.553 140.124 273.178 132.574 268.291C129.214 266.106 125.878 263.886 122.546 261.658C117.818 258.5 113.082 255.353 108.334 252.226C77.4997 231.914 77.4997 231.914 64.39 221.22C63.8362 220.778 63.2823 220.335 62.7117 219.88C36.9654 199.279 17.0082 174.642 6.38997 143.22C5.98907 142.127 5.58817 141.034 5.17512 139.908C-3.15742 116.66 -1.137 85.1821 9.14558 62.9438C22.013 36.5993 41.73 17.2199 69.1048 6.31415C101.447 -4.45385 136.194 -2.06936 164.226 18.279Z" fill="#C4956A"/>
          <path d="M360.534 28.5759C361.565 29.454 362.592 30.3352 363.616 31.2204C364.376 31.8765 365.135 32.5327 365.917 33.2087C380.378 46.7421 389.658 65.3088 394.616 84.2204C394.863 85.1047 395.109 85.989 395.363 86.9001C397.637 96.7211 396.959 107.215 396.616 117.22C396.591 117.971 396.566 118.722 396.54 119.496C394.8 157.388 370.654 190.546 343.616 215.22C339.116 219.106 334.384 222.673 329.616 226.22C328.446 227.109 327.275 227.999 326.105 228.888C312.059 239.469 297.08 248.685 282.21 258.048C263.621 269.768 245.054 282.218 228.87 297.154C226.87 298.988 224.823 300.731 222.741 302.47C217.854 306.708 213.592 311.545 209.253 316.33C207.412 318.348 205.576 320.321 203.616 322.22C210.765 290.575 240.653 261.329 264.593 241.025C268.128 237.872 271.402 234.452 274.71 231.064C276.858 228.912 279.099 226.909 281.402 224.924C285.976 220.959 290.277 216.751 294.554 212.47C295.346 211.678 296.138 210.886 296.954 210.07C301.872 205.104 306.468 200.076 310.765 194.56C312.534 192.325 314.407 190.288 316.366 188.22C331.999 170.774 342.076 150.505 348.616 128.22C348.804 127.6 348.991 126.98 349.184 126.341C352.248 111.326 351.011 92.059 344.616 78.2204C344.17 77.2278 343.724 76.2352 343.265 75.2126C333.654 55.9377 316.619 43.3523 296.679 36.3454C295.328 35.9606 293.973 35.5866 292.616 35.2204C291.966 35.0434 291.315 34.8664 290.644 34.684C284.539 33.176 278.702 32.8718 272.429 32.9079C271.417 32.9128 270.404 32.9177 269.361 32.9228C251.855 33.1954 237.326 38.2194 223.616 49.2204C222.628 49.9835 221.639 50.7466 220.62 51.5329C217.27 54.3436 214.888 57.6299 212.429 61.2204C212.004 61.8237 211.579 62.427 211.142 63.0485C208.826 66.3626 206.65 69.7228 204.616 73.2204C202.652 69.2923 205.697 63.5724 207.038 59.5329C214.416 38.6392 230.114 23.0691 249.616 13.2204C286.383 -4.00647 329.669 2.90498 360.534 28.5759Z" fill="#7A9E7E"/>
        </svg>
        <span class="font-display italic text-3xl text-clay leading-none">Mi</span>
        <span class="font-display font-semibold text-3xl text-cream leading-none">Voz</span>
        <span class="font-body text-xs tracking-[4px] uppercase text-sage ml-1 hidden sm:block">Interpreting</span>
      </a>

      <!-- Nav -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/" class="text-sm text-mist hover:text-clay transition-colors">Services</a>
        <a href="/in-person" class="text-sm text-mist hover:text-clay transition-colors">In-Person Interpreting</a>
        <a href="/remote" class="text-sm text-mist hover:text-clay transition-colors">Remote Interpreting</a>
        <a href="/providers" class="text-sm text-mist hover:text-clay transition-colors">For Providers</a>
        <a href="/about" class="text-sm text-mist hover:text-clay transition-colors">About</a>
      </nav>

      <div class="flex items-center gap-3">
        <!-- CTA -->
        <a href="/contact"
           class="bg-clay text-white text-sm font-medium px-5 py-2.5 rounded-full hover:bg-earth transition-colors whitespace-nowrap">
          Book a Session
        </a>
        <!-- Hamburger -->
        <button id="menu-toggle" aria-label="Open menu"
                class="md:hidden flex flex-col justify-center items-center gap-1.5 w-8 h-8">
          <span class="block w-5 h-px bg-mist transition-all"></span>
          <span class="block w-5 h-px bg-mist transition-all"></span>
          <span class="block w-5 h-px bg-mist transition-all"></span>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-deep-forest border-t border-forest/40">
      <nav class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-4">
        <a href="/" class="text-sm text-mist hover:text-clay transition-colors py-1">Services</a>
        <a href="/in-person" class="text-sm text-mist hover:text-clay transition-colors py-1">In-Person Interpreting</a>
        <a href="/remote" class="text-sm text-mist hover:text-clay transition-colors py-1">Remote Interpreting</a>
        <a href="/providers" class="text-sm text-mist hover:text-clay transition-colors py-1">For Providers</a>
        <a href="/about" class="text-sm text-mist hover:text-clay transition-colors py-1">About</a>
        <a href="/contact" class="text-sm text-mist hover:text-clay transition-colors py-1">Contact</a>
      </nav>
    </div>
  </header>

  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  </script>

  <!-- MAIN -->
  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="bg-deep-forest text-mist mt-24">
    <div class="max-w-6xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Brand -->
      <div>
        <div class="flex items-baseline gap-1.5 mb-3">
          <svg width="28" height="23" viewBox="0 0 397 323" fill="none" xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0">
            <path d="M164.226 18.279C179.974 30.6528 190.604 45.7832 195.39 65.2204C195.703 68.0559 195.68 70.3745 195.39 73.2204C192.99 70.1905 191.167 67.0522 189.327 63.6579C178.778 45.5923 163.937 36.8428 144.273 31.6628C123.544 26.5901 101.082 31.4424 82.9837 42.2556C71.6177 49.6027 63.0389 58.4555 56.39 70.2204C56.002 70.8856 55.6139 71.5507 55.2142 72.236C45.8374 89.4691 44.7789 111.322 49.7518 130.087C57.9038 157.343 74.5788 179.728 93.7025 200.314C96.1327 202.942 98.5163 205.604 100.89 208.283C107.601 215.751 114.654 222.831 122.296 229.345C124.93 231.704 127.408 234.205 129.89 236.72C132.882 239.753 135.881 242.722 139.14 245.47C148.545 253.512 157.588 262.614 165.39 272.22C166.629 273.719 166.629 273.719 167.894 275.248C177.656 287.229 185.998 300.119 192.39 314.22C192.993 315.529 192.993 315.529 193.609 316.865C194.39 319.22 194.39 319.22 193.39 322.22C192.914 321.6 192.439 320.98 191.949 320.341C182.153 307.949 170.915 296.846 158.39 287.22C157.045 286.17 155.7 285.119 154.355 284.068C147.258 278.553 140.124 273.178 132.574 268.291C129.214 266.106 125.878 263.886 122.546 261.658C117.818 258.5 113.082 255.353 108.334 252.226C77.4997 231.914 77.4997 231.914 64.39 221.22C63.8362 220.778 63.2823 220.335 62.7117 219.88C36.9654 199.279 17.0082 174.642 6.38997 143.22C5.98907 142.127 5.58817 141.034 5.17512 139.908C-3.15742 116.66 -1.137 85.1821 9.14558 62.9438C22.013 36.5993 41.73 17.2199 69.1048 6.31415C101.447 -4.45385 136.194 -2.06936 164.226 18.279Z" fill="#C4956A"/>
            <path d="M360.534 28.5759C361.565 29.454 362.592 30.3352 363.616 31.2204C364.376 31.8765 365.135 32.5327 365.917 33.2087C380.378 46.7421 389.658 65.3088 394.616 84.2204C394.863 85.1047 395.109 85.989 395.363 86.9001C397.637 96.7211 396.959 107.215 396.616 117.22C396.591 117.971 396.566 118.722 396.54 119.496C394.8 157.388 370.654 190.546 343.616 215.22C339.116 219.106 334.384 222.673 329.616 226.22C328.446 227.109 327.275 227.999 326.105 228.888C312.059 239.469 297.08 248.685 282.21 258.048C263.621 269.768 245.054 282.218 228.87 297.154C226.87 298.988 224.823 300.731 222.741 302.47C217.854 306.708 213.592 311.545 209.253 316.33C207.412 318.348 205.576 320.321 203.616 322.22C210.765 290.575 240.653 261.329 264.593 241.025C268.128 237.872 271.402 234.452 274.71 231.064C276.858 228.912 279.099 226.909 281.402 224.924C285.976 220.959 290.277 216.751 294.554 212.47C295.346 211.678 296.138 210.886 296.954 210.07C301.872 205.104 306.468 200.076 310.765 194.56C312.534 192.325 314.407 190.288 316.366 188.22C331.999 170.774 342.076 150.505 348.616 128.22C348.804 127.6 348.991 126.98 349.184 126.341C352.248 111.326 351.011 92.059 344.616 78.2204C344.17 77.2278 343.724 76.2352 343.265 75.2126C333.654 55.9377 316.619 43.3523 296.679 36.3454C295.328 35.9606 293.973 35.5866 292.616 35.2204C291.966 35.0434 291.315 34.8664 290.644 34.684C284.539 33.176 278.702 32.8718 272.429 32.9079C271.417 32.9128 270.404 32.9177 269.361 32.9228C251.855 33.1954 237.326 38.2194 223.616 49.2204C222.628 49.9835 221.639 50.7466 220.62 51.5329C217.27 54.3436 214.888 57.6299 212.429 61.2204C212.004 61.8237 211.579 62.427 211.142 63.0485C208.826 66.3626 206.65 69.7228 204.616 73.2204C202.652 69.2923 205.697 63.5724 207.038 59.5329C214.416 38.6392 230.114 23.0691 249.616 13.2204C286.383 -4.00647 329.669 2.90498 360.534 28.5759Z" fill="#7A9E7E"/>
          </svg>
          <span class="font-display italic text-2xl text-clay">Mi</span>
          <span class="font-display font-semibold text-2xl text-cream">Voz</span>
        </div>
        <p class="text-xs tracking-[4px] uppercase text-sage mb-4">Interpreting</p>
        <p class="text-sm leading-relaxed text-mist/80 max-w-xs">
          Professional Spanish medical interpreting — in-person, video, and phone.
          Your voice. Their care.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-xs tracking-[3px] uppercase text-clay mb-5 font-medium">Navigation</h3>
        <ul class="space-y-3">
          <li><a href="/" class="text-sm text-mist/80 hover:text-clay transition-colors">Home</a></li>
          <li><a href="/in-person" class="text-sm text-mist/80 hover:text-clay transition-colors">In-Person Interpreting</a></li>
          <li><a href="/remote" class="text-sm text-mist/80 hover:text-clay transition-colors">Remote Interpreting (Video & Phone)</a></li>
          <li><a href="/providers" class="text-sm text-mist/80 hover:text-clay transition-colors">For Providers</a></li>
          <li><a href="/about" class="text-sm text-mist/80 hover:text-clay transition-colors">About Michelle</a></li>
          <li><a href="/contact" class="text-sm text-mist/80 hover:text-clay transition-colors">Contact & Book</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xs tracking-[3px] uppercase text-clay mb-5 font-medium">Get in Touch</h3>
        <ul class="space-y-3">
          <li class="text-sm text-mist/80">✉️ michelle@mivozinterpreting.com</li>
          <li class="text-sm text-mist/80">📍 Walnut Creek, CA · Diablo Valley</li>
          <li class="text-sm text-mist/80 mt-1">HIPAA Compliant · CMI Certified</li>
          <li class="mt-4 flex items-center gap-3">
            <a href="/contact"
               class="inline-block bg-clay text-white text-xs font-medium px-4 py-2 rounded-full hover:bg-earth transition-colors">
              Book a Session →
            </a>
            <a href="https://linkedin.com/company/mi-voz-interpreting"
               target="_blank" rel="noopener noreferrer"
               class="text-mist/50 hover:text-clay transition-colors text-xs"
               aria-label="Mi Voz on LinkedIn">
              LinkedIn ↗
            </a>
            <a href="https://share.google/GFoLah0LJV7GRKkvA"
               target="_blank" rel="noopener noreferrer"
               class="text-mist/50 hover:text-clay transition-colors text-xs"
               aria-label="Mi Voz Google Profile">
              Google Profile ↗
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-forest/50 max-w-6xl mx-auto px-6 py-6 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-mist/50">© {new Date().getFullYear()} Mi Voz Interpreting. All rights reserved.</p>
      <p class="text-xs text-mist/50 italic font-display">"Your voice. Their care."</p>
    </div>
  </footer>

</body>
</html>
